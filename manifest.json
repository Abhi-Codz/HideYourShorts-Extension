{
    "manifest_version": 3,
    "name": "YouTube Shorts Toggle",
    "version": "1.0.0",
    "description": "Hide YouTube Shorts suggestions with a toggle.",
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://www.youtube.com/*"
    ],
    "content_scripts": [
      {
        "matches": [
          "https://www.youtube.com/*"
        ],
        "js": [
          "content.js"
        ],
        "run_at": "document_idle"
      }
    ],
    "action": {
      "default_popup": "popup.html"
    }
  }